# Keep the build context small.
.git
.gitignore
__pycache__
*.pyc
.venv
venv
.ipynb_checkpoints

# Training artefacts — the inference image doesn't need any of these.
notebooks/
data/
figures/
# The inference model IS baked into the image (see Dockerfile). Keep the
# resnet50.keras file in the build context; exclude everything else under models/.
models/*
!models/resnet50.keras
docs/
proposal.md
README.md
requirements.txt

# Editor / OS
.DS_Store
.vscode/
.idea/
.claude/
